generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model QuestionBank {
  id        String     @id @default(cuid())
  name      String
  skill     String?
  createdAt DateTime   @default(now())
  questions Question[]
  exams     Exam[]
}

enum Choice {
  A
  B
  C
  D
}

model Question {
  id        String       @id @default(cuid())
  bank      QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  bankId    String
  number    Int?
  text      String
  optionA   String
  optionB   String
  optionC   String
  optionD   String
  correct   Choice
  level     String?
  createdAt DateTime     @default(now())

  @@index([bankId])
}

model Exam {
  id           String       @id @default(cuid())
  name         String
  bank         QuestionBank @relation(fields: [bankId], references: [id])
  bankId       String
  numQuestions Int
  durationMin  Int
  createdAt    DateTime     @default(now())
  attempts     Attempt[]
}

model Candidate {
  id           String    @id @default(cuid())
  fullName     String
  phone        String
  organization String?
  department   String?
  candidateRef String?
  createdAt    DateTime  @default(now())
  attempts     Attempt[]
}

model Attempt {
  id          String    @id @default(cuid())
  exam        Exam      @relation(fields: [examId], references: [id])
  examId      String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  candidateId String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  total       Int
  correct     Int       @default(0)
  wrong       Int       @default(0)
  score       Float     @default(0)
  percentage  Float     @default(0)
  timeUsedSec Int       @default(0)
  payload     Json
  createdAt   DateTime  @default(now())

  @@index([examId])
  @@index([candidateId])
}

model Setting {
  id             Int      @id @default(1)
  telegramChatId String?
  updatedAt      DateTime @updatedAt
}
